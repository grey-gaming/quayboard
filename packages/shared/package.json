{
  "name": "@quayboard/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./schemas/health": {
      "types": "./src/schemas/health.ts",
      "source": "./src/schemas/health.ts",
      "import": "./dist/schemas/health.js"
    }
  },
