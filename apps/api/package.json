{
  "name": "@quayboard/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@quayboard/shared": "workspace:*",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.40.0",
    "fastify": "^5.2.1",
    "postgres": "^3.4.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.8"
  },
  "scripts": {
    "dev": "node --conditions=source --watch --import tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:migrate": "node --conditions=source --import tsx src/db/migrate.ts",
    "start": "node dist/index.js"
  }
}
